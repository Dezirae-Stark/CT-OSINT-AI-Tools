# ─── GhostExodus OSINT Platform — Environment Configuration ─────────────────
# Copy this file to .env and fill in your values before starting.

# ─── Telegram API ────────────────────────────────────────────────────────────
# Obtain from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+447700000000

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRY_HOURS=24

# ─── Ollama / LLM ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text
LLM_CONTEXT_WINDOW=4096

# ─── Storage Paths ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chromadb
SQLITE_PATH=./data/sqlite/ghostexodus.db
EVIDENCE_DIR=./data/evidence
REPORTS_DIR=./data/reports
TELEGRAM_SESSION_PATH=./data/telegram

# ─── SMTP Email Alerts (optional) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=analyst@example.com

# ─── ntfy.sh Push Notifications (optional) ───────────────────────────────────
# Create a topic at https://ntfy.sh — e.g. "ghostexodus-alerts-abc123"
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "development" to enable CORS for frontend dev server
ENV=production
FRONTEND_DEV_ORIGIN=http://localhost:5173
